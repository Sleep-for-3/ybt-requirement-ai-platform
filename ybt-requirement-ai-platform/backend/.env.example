APP_NAME=YBT Requirement AI Platform
API_PREFIX=/api
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=sqlite:////app/data/ybt.db
STORAGE_PROVIDER=local
STORAGE_DIR=/app/storage

AUTH_MODE=optional
APP_SECRET_KEY=
JWT_SECRET_KEY=

TASK_QUEUE_PROVIDER=inline
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Keys remain empty in this public template. Configure them only in backend/.env.
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_API_KEY_ENV_NAME=OPENAI_API_KEY
OPENAI_API_KEY=

EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=
EMBEDDING_API_KEY_ENV_NAME=EMBEDDING_API_KEY
EMBEDDING_API_KEY=

VECTOR_STORE_PROVIDER=mock
MILVUS_URI=
MILVUS_TOKEN=

CORS_ORIGINS=http://localhost:3000

S3_ENDPOINT_URL=
S3_BUCKET_NAME=
SAFE_SQL_DEFAULT_LIMIT=100
SAFE_SQL_MAX_LIMIT=1000
SAFE_SQL_TIMEOUT_SECONDS=30
ENABLE_POSTGRES_DATASOURCE=true
ENABLE_SQLITE_DATASOURCE=true
ENABLE_ORACLE_DATASOURCE=false
ENABLE_MYSQL_DATASOURCE=false
ENABLE_DB2_DATASOURCE=false
ENABLE_HIVE_DATASOURCE=false
