APP_NAME=YBT Requirement AI Platform
API_PREFIX=/api
APP_SECRET_KEY=
JWT_SECRET_KEY=
AUTH_MODE=optional
ENVIRONMENT=development
DATABASE_URL=sqlite:////app/data/ybt.db
STORAGE_DIR=/app/storage
CORS_ORIGINS=http://localhost:3000
TASK_QUEUE_PROVIDER=inline
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
STORAGE_PROVIDER=local
S3_ENDPOINT_URL=
S3_BUCKET_NAME=

# API keys are referenced by environment-variable name and are never stored in model profiles.
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY_ENV_NAME=OPENAI_API_KEY

EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY_ENV_NAME=EMBEDDING_API_KEY

COZE_ENABLED=false
COZE_BASE_URL=http://coze-studio:8888
COZE_API_KEY=
COZE_WORKFLOW_ID=

VECTOR_STORE_PROVIDER=mock
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=

SAFE_SQL_DEFAULT_LIMIT=100
SAFE_SQL_MAX_LIMIT=1000
SAFE_SQL_TIMEOUT_SECONDS=30

ENABLE_POSTGRES_DATASOURCE=true
ENABLE_SQLITE_DATASOURCE=true
ENABLE_ORACLE_DATASOURCE=false
ENABLE_MYSQL_DATASOURCE=false
ENABLE_DB2_DATASOURCE=false
ENABLE_HIVE_DATASOURCE=false
