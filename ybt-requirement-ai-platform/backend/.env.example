APP_NAME=YBT Requirement AI Platform
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg://ybt:ybt_password@postgres:5432/ybt_requirement_ai
STORAGE_DIR=/app/storage
CORS_ORIGINS=http://localhost:3000

# Local demo can use mock. Switch to openai or vllm when a compatible endpoint is available.
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

COZE_ENABLED=false
COZE_BASE_URL=http://coze-studio:8888
COZE_API_KEY=
COZE_WORKFLOW_ID=

VECTOR_STORE_PROVIDER=mock
